---
import Layout from "../layouts/layout.astro";
import Vh from "../components/vh.astro";
import ProjectCard from "../components/project-card.astro";
---

<Layout title="Projects">
    <Vh>
        <ProjectCard title="Open-ttp" link="https://github.com/liampallett/open-ttp" description=
		"A simple C++ program for simulating and decoding 64-byte packed binary telemetry data with integrity validation.
		">
		</ProjectCard>

        <ProjectCard title="Newtonian Orbit Mechanics" link="https://github.com/liampallett/newtonian_orbit_mechanics" description=
		"Simple orbital mechanics simulator using the Newtonian model.
		">
		</ProjectCard>
    </Vh>
</Layout>